{
	"version": "0.6.10",
	"content_scripts": [
		{
			"matches": [
				"*://ficbook.net/*",
				"*://fic.fan/*"
			],
			"js": [
				"js/content.js",
				"js/add-divs-pages.js"
			],
			"run_at": "document_start"
		}
	],
	"web_accessible_resources": [
		{
			"resources": [
				"css/old-fields-ficbook.css",
				"js/add-divs-pages.js"
			],
			"matches": [
				"*://ficbook.net/*",
				"*://fic.fan/*"
			]
		}
	],
	"host_permissions": [
		"*://ficbook.net/*",
		"*://fic.fan/*"
	],
	"manifest_version": 3,
	"name": "Ficbook Old Style",
	"description": "Помогает вернуть некоторый старый дизайн сайта Ficbook. В особенности старые книжные поля.",
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self';"
	},
	"permissions": [
		"storage",
		"activeTab"
	],
	"action": {
		"default_popup": "popup/popup.html"
	},
	"icons": {
		"16": "icons/icon16.png",
		"32": "icons/icon32.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	}
}